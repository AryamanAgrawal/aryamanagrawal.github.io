---
/**
 * Tufte-style sidenote. Renders in the gutter column on desktop,
 * collapses to an inline footnote on narrow viewports.
 *
 * Usage in MDX:
 *   Some prose <Sidenote>The annotation.</Sidenote> continuing.
 */
interface Props {
  id?: string;
}
const { id } = Astro.props;
const num = id ?? Math.random().toString(36).slice(2, 6);
---
<span class="sidenote-mark" aria-describedby={`sn-${num}`}>&nbsp;</span>
<span class="sidenote" id={`sn-${num}`} role="note"><slot /></span>

<style>
  /* Mark: a small cyan dot in the body column where the note is anchored. */
  .sidenote-mark {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--c-accent);
    vertical-align: super;
    margin-left: 2px;
  }

  /* Desktop: float the note into the gutter. The .page grid's left
     gutter sits before the body column, so negative margin pulls it there. */
  .sidenote {
    display: block;
    float: left;
    clear: left;
    width: 8rem;
    margin-left: -10rem;
    margin-top: 0.4em;
    font-family: var(--font-prose);
    font-style: italic;
    font-size: var(--t-12);
    line-height: 1.5;
    color: var(--c-muted);
    text-align: right;
  }

  /* Mobile: collapse to an inline footnote-style aside. */
  @media (max-width: 720px) {
    .sidenote {
      float: none;
      width: auto;
      margin: var(--s-3) 0 var(--s-3) var(--s-6);
      text-align: left;
      border-left: 2px solid var(--c-line);
      padding-left: var(--s-4);
    }
  }
</style>
