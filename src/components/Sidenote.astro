---
/**
 * Tufte-style sidenote with numbered references — matches design-sheet §07
 * (Mode B: gutter-mounted marginalia, mono [N] markers, Tufte register).
 *
 * Renders as a `[N]` superscript at the anchor point, with a matching
 * `[N]`-prefixed annotation in the gutter column. Numbering is automatic
 * via CSS counters reset on `.prose` (see global.css).
 *
 * On desktop, the note floats into the left gutter; on narrow viewports
 * it collapses to an inline footnote-style aside.
 *
 * Usage in MDX:
 *   Some prose <Sidenote>The annotation.</Sidenote> continuing.
 */
interface Props {
  id?: string;
}
const { id } = Astro.props;
const num = id ?? Math.random().toString(36).slice(2, 6);
---
<sup class="sidenote-mark" aria-describedby={`sn-${num}`}></sup>
<span class="sidenote" id={`sn-${num}`} role="note"><slot /></span>

<style>
  /* Marker: numbered superscript [N] — mono, info color.
     Counter increments here; the matching gutter note reads the same value.
     No cursor: help — the gutter note is already visible, so there's
     nothing for hover to reveal. */
  .sidenote-mark {
    counter-increment: sidenote;
    font-family: var(--font-mono);
    font-size: 0.65em;
    color: var(--c-info, var(--c-accent));
    margin-left: 1px;
  }
  .sidenote-mark::before {
    content: "[" counter(sidenote) "]";
  }

  /* Gutter note: italic prose, [N] prefix in mono normal-style. */
  .sidenote {
    display: block;
    float: left;
    clear: left;
    width: 8rem;
    margin-left: -10rem;
    margin-top: 0.4em;
    font-family: var(--font-prose);
    font-style: italic;
    font-size: var(--t-12);
    line-height: 1.5;
    color: var(--c-muted);
    text-align: right;
  }
  .sidenote::before {
    content: "[" counter(sidenote) "] ";
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.9em;
    color: var(--c-info, var(--c-accent));
    margin-right: 4px;
  }

  /* Mobile: collapse to inline footnote-style aside. */
  @media (max-width: 720px) {
    .sidenote {
      float: none;
      width: auto;
      margin: var(--s-3) 0 var(--s-3) var(--s-6);
      text-align: left;
      border-left: 2px solid var(--c-line);
      padding-left: var(--s-4);
    }
  }
</style>
