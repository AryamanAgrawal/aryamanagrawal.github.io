---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const poems = (await getCollection('poems', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title="Poems" description="Poems.">
  <main class="page">

    <div class="row">
      <div class="meta">(02)</div>
      <div class="body">
        <p class="kicker"><a href="/">← Home</a></p>
        <h1 class="page-title">Poems</h1>
      </div>
    </div>

    <hr />

    {poems.map(p => (
      <a href={`/poems/${p.id}`} class="row item">
        <div class="meta">{fmtDate(p.data.date)}</div>
        <div class="body">
          <div class="item-title italic">{p.data.title}</div>
        </div>
      </a>
    ))}

  </main>
</Base>
