---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);
const poems = (await getCollection('poems', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title="Aryaman Agrawal" description="Writing on minds, machines, and philosophy. Making the art that emerges in-between.">
  <main class="page">

    {/* IDENTITY  */}
    <div class="row">
      <div class="meta"></div>
      <div class="body">
        <p class="kicker">Aryaman Agrawal · San Francisco</p>
        <h1 class="ident">
          Writing on minds, machines, and <em>philosophy</em>. Making the art that emerges in-between.
        </h1>
        <p class="lede">
          Engineer at Falconer. Previously AI at Ironclad, philosophy and CS at UMass, programming for fun before all that.
        </p>
      </div>
    </div>

    {/* NOW  */}
    <div class="row now">
      <div class="meta">
        <span class="now-label"><span class="pulse" aria-hidden="true"></span>Now</span>
      </div>
      <div class="body italic">teaching agents to learn and forget. listening to Hozier. ai-thinking my way through most of it.</div>
    </div>

    <hr />

    {/* WRITING — section header  */}
    <div class="row sec-head">
      <div class="meta">(01)</div>
      <div class="body row-split">
        <span class="sec-name">Writing</span>
        <a href="/essays" class="sec-all">All essays →</a>
      </div>
    </div>

    {/* WRITING — items  */}
    {essays.map(e => (
      <a href={`/essays/${e.id}`} class="row item">
        <div class="meta">{fmtDate(e.data.date)}</div>
        <div class="body">
          <div class="item-title">{e.data.title}</div>
          <p class="item-summary">{e.data.summary}</p>
        </div>
      </a>
    ))}

    <hr />

    {/* POEMS — section header  */}
    <div class="row sec-head">
      <div class="meta">(02)</div>
      <div class="body row-split">
        <span class="sec-name">Poems</span>
        <a href="/poems" class="sec-all">All poems →</a>
      </div>
    </div>

    {/* POEMS — items  */}
    {poems.map(p => (
      <a href={`/poems/${p.id}`} class="row item">
        <div class="meta">{fmtDate(p.data.date)}</div>
        <div class="body">
          <div class="item-title italic">{p.data.title}</div>
        </div>
      </a>
    ))}

    <hr />

    {/* FOOTER  */}
    <div class="row">
      <div class="meta"></div>
      <div class="body footer-meta">
        <a href="https://github.com/AryamanAgrawal">GitHub</a> · <a href="https://www.linkedin.com/in/aryamanagraw/">LinkedIn</a> · <a href="https://x.com/AryamanAgrawal5">X</a>
      </div>
    </div>

  </main>
</Base>

<style>
  /* Home-only — identity hero + Now line. Grid + atoms live in global.css. */
  .ident {
    font-family: var(--font-display);
    font-size: var(--t-49);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0;
    max-width: 22ch;
  }
  .ident em {
    font-family: var(--font-prose);
    font-style: italic;
    font-weight: 400;
    color: var(--c-accent);
  }
  .lede {
    font-family: var(--font-prose);
    font-size: var(--t-14);
    color: var(--c-text);
    opacity: 0.7;
    line-height: 1.55;
    margin-top: var(--s-6);
    text-wrap: balance;
  }
  .now-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .pulse {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 999px;
    background: var(--c-accent);
    flex-shrink: 0;
  }
  .now .meta, .now .body { align-self: center; padding-top: 0; }
  .now .body { font-size: var(--t-16); color: var(--c-text); opacity: 0.92; line-height: 1.5; }
</style>
