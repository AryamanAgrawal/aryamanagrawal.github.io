---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const photos = (await getCollection('photos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title="Photography" description="Photo essays — rolls and frames.">
  <main class="page">

    <div class="row">
      <div class="meta">(03)</div>
      <div class="body">
        <p class="kicker"><a href="/">← Home</a></p>
        <h1 class="page-title">Rolls</h1>
      </div>
    </div>

    <hr />

    {photos.map(p => (
      <a href={`/photos/${p.id}`} class="row item">
        <div class="meta">{fmtDate(p.data.date)}</div>
        <div class="body">
          <div class="item-title">{p.data.title}</div>
          {p.data.rollName && (
            <p class="roll-meta">
              {p.data.rollName}{p.data.frameCount ? ` · ${p.data.frameCount} frames` : ''}
            </p>
          )}
          {p.data.summary && <p class="item-summary">{p.data.summary}</p>}
        </div>
      </a>
    ))}

  </main>
</Base>

<style>
  .roll-meta {
    font-family: var(--font-mono);
    font-size: var(--t-12);
    color: var(--c-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: var(--s-2);
  }
</style>
