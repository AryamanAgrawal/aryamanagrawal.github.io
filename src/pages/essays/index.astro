---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title="Essays" description="Essays on memory, agents, philosophy.">
  <main class="page">

    <div class="row">
      <div class="meta">(01)</div>
      <div class="body">
        <p class="kicker"><a href="/">← Home</a></p>
        <h1 class="page-title">Essays</h1>
      </div>
    </div>

    <hr />

    {essays.map(e => (
      <a href={`/essays/${e.id}`} class="row item">
        <div class="meta">{fmtDate(e.data.date)}</div>
        <div class="body">
          <div class="item-title">{e.data.title}</div>
          {e.data.summary && <p class="item-summary">{e.data.summary}</p>}
        </div>
      </a>
    ))}

  </main>
</Base>
