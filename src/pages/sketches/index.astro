---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const sketches = (await getCollection('sketches', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title="Sketches" description="Notebook pages.">
  <main class="page">

    <div class="row">
      <div class="meta">(04)</div>
      <div class="body">
        <p class="kicker"><a href="/">← Home</a></p>
        <h1 class="page-title">Notebook</h1>
      </div>
    </div>

    <hr />

    {sketches.map(s => (
      <a href={`/sketches/${s.id}`} class="row item">
        <div class="meta">{fmtDate(s.data.date)}</div>
        <div class="body">
          <div class="item-title italic">{s.data.title}</div>
          <p class="page-coords">N{s.data.notebook} · p.{s.data.page} · {s.data.orientation}</p>
        </div>
      </a>
    ))}

  </main>
</Base>

<style>
  .page-coords {
    font-family: var(--font-mono);
    font-size: var(--t-12);
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: var(--s-2);
  }
</style>
