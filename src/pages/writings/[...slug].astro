---
import Base from '@/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const writings = await getCollection('writings', ({ data }) => !data.draft);
  return writings.map(writing => ({ params: { slug: writing.id }, props: { writing } }));
}

const { writing } = Astro.props;
const { Content } = await render(writing);
const site = Astro.site!.toString().replace(/\/$/, '');
const url = `${site}/writings/${writing.id}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: writing.data.title,
  description: writing.data.summary,
  datePublished: writing.data.date.toISOString(),
  dateModified: writing.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Aryaman Agrawal',
    url: site,
    sameAs: [
      'https://github.com/AryamanAgrawal',
      'https://www.linkedin.com/in/aryamanagraw/',
      'https://x.com/AryamanAgrawal5',
    ],
  },
  url,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: writing.data.tags?.join(', '),
};

const fmt = writing.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---
<Base title={writing.data.title} description={writing.data.summary} type="article" publishedTime={writing.data.date} jsonLd={jsonLd} ogSlug={`writings/${writing.id}`}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />

  <main class="page">

    <div class="row">
      <div class="meta">{fmt}</div>
      <div class="body">
        <p class="kicker"><a href="/writings">← Writings</a></p>
        <h1 class="writing-title">{writing.data.title}</h1>
        {writing.data.summary && <p class="lede">{writing.data.summary}</p>}
      </div>
    </div>

    <hr />

    <div class="row">
      <div class="meta"></div>
      <div class="body prose"><Content /></div>
    </div>

  </main>
</Base>

<style>
  .writing-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--t-49);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0;
  }
  .lede {
    font-family: var(--font-prose);
    font-size: var(--t-20);
    color: var(--c-text);
    opacity: 0.85;
    line-height: 1.5;
    margin: var(--s-6) 0 0;
  }
</style>
